---
interface Props {
  tag: string;
  size?: "sm" | "lg";
}

const { tag, size = "sm" } = Astro.props;
---

<li class={`inline-block ${size === "sm" ? "my-1 underline-offset-4" : "my-3 text-lg underline-offset-8"}`}>
  <a
    href={`/tags/${tag}/`}
    class={`${size === "sm" ? "text-sm" : "text-base"} pr-2 group relative font-medium text-skin-accent/75 hover:text-skin-accent hover:underline hover:decoration-dashed`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class={`${size === "sm" ? "-mr-2 h-6 w-6" : "-mr-3 h-8 w-8"} inline-block fill-skin-accent/75 group-hover:fill-skin-accent`}
    >
      <path
        d="M16.018 3.815 15.232 8h-4.966l.716-3.815-1.964-.37L8.232 8H4v2h3.857l-.751 4H3v2h3.731l-.714 3.805 1.965.369L8.766 16h4.966l-.714 3.805 1.965.369.783-4.174H20v-2h-3.859l.751-4H21V8h-3.733l.716-3.815-1.965-.37zM14.106 14H9.141l.751-4h4.966l-.752 4z"
      ></path>
    </svg>
    &nbsp;<span>{tag}</span>
  </a>
</li>
