---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  href: string;
  class?: string;
  ariaLabel?: string;
}

const { href, class: className, ariaLabel, ...props } = Astro.props;
---

<a
  href={href}
  class:list={["group", className]}
  aria-label={ariaLabel}
  {...props}
>
  <slot />
</a>
